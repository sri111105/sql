select SONG_ID,SUM(DURATION) AS TOTAL_LISTEN_TIME FROM USER_LISTENING
GROUP BY SONG_ID 
ORDER BY 
TOTAL_LISTEN_TIME desc;
SELECT SONG_ID,SUM(PLAY_COUNT) AS TOTAL_PLAY_COUNT FROM SONG_PLAY_HISTORY
GROUP BY SONG_ID 
ORDER BY SUM(PLAY_COUNT) DESC;
SELECT SONG_ID,SUM(PLAY_COUNT) AS TOTAL_PLAY_COUNT FROM SONG_PLAY_HISTORY
GROUP BY SONG_ID 
HAVING SUM(PLAY_COUNT)>100
ORDER BY SUM(PLAY_COUNT) DESC;

SELECT USER_ID,SUM(DURATION) AS TOTAL_DURATION FROM USER_LISTENING
GROUP BY USER_ID 
ORDER BY SUM(DURATION) DESC;
select USER_ID,COUNT(DURATION) AS TOTAL_LISTENINGS FROM USER_LISTENING
GROUP BY USER_ID 
HAVING COUNT(DURATION)>1
ORDER BY 
TOTAL_LISTENINGS desc;
