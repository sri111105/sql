Q1 (COUNT)

 Find number of employees in each department

SELECT department,
       COUNT(*) AS employee_count
FROM employee
GROUP BY department; 
Concept:

COUNT(*) = total rows per group

 Q2 (SUM)

 Find total salary given in each city

SELECT city,
       SUM(salary) AS total_salary
FROM employee
GROUP BY city;
 Concept:

 SUM() = total of values

 Q3 (AVG)

 Find average salary per department

SELECT department,
       AVG(salary) AS avg_salary
FROM employee
GROUP BY department;
 Concept:

 AVG() = mean value per group

 Q4 (MAX)

 Find highest salary in each city

SELECT city,
       MAX(salary) AS max_salary
FROM employee
GROUP BY city;
 Concept:

 MAX() = highest value in group

 Q5 (MIN + HAVING)

 Find departments where minimum salary is greater than 30000

SELECT department,
       MIN(salary) AS min_salary
FROM employee
GROUP BY department
HAVING MIN(salary) > 30000;
